/* 斯诺克记分页面样式 */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 200rpx 30rpx 160rpx; /* 顶部留出导航栏空间 */
  box-sizing: border-box;
}

/* 自定义导航栏 */
.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: #f5f7fa;
}

.nav-bar-content {
  padding-top: 88rpx;
  padding-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-bar-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
}

/* 顶部标题 */
.header {
  text-align: center;
  margin: 20rpx 0;
  padding: 0;
}

.title {
  color: #1890ff;
  font-size: 48rpx;
  font-weight: bold;
}

/* 红球计数器 */
.red-balls-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx 30rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.red-balls-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.red-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #ff4d4f;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
}

.red-count {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.red-number {
  font-size: 48rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.red-total {
  font-size: 28rpx;
  color: #999;
}

/* 选手区域 - 左右布局 */
.players-section {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

/* 开球前选手区域居中显示 */
.players-section.pre-game {
  margin-top: 100rpx;
}

.player-card {
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.player-card.active {
  border-color: #1890ff;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.15);
}

.player-card.selectable {
  opacity: 0.7;
}

.player-card.selectable:active {
  opacity: 1;
  transform: scale(0.98);
}

/* 选手头部 */
.player-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.player-avatar {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  background: #e6f4ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.player-name-box {
  text-align: center;
}

.player-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.name-input {
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  width: 160rpx;
  text-align: center;
  background: #fafafa;
  transition: all 0.3s;
}

.name-input:focus {
  border-color: #1890ff;
  background: #fff;
}

/* 分数显示 */
.score-display {
  text-align: center;
  margin-bottom: 16rpx;
}

.score-number {
  font-size: 72rpx;
  color: #1890ff;
  font-weight: bold;
}

/* 状态标签 */
.current-tag {
  font-size: 24rpx;
  color: #1890ff;
  background: #e6f4ff;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  margin-top: 8rpx;
}

.select-tag {
  font-size: 24rpx;
  color: #1890ff;
  background: #e6f4ff;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  margin-top: 16rpx;
}

/* 中间操作按钮区 */
.center-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin: 20rpx 0;
}

.center-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.switch-btn-center {
  background: linear-gradient(135deg, #1890ff, #36cfc9);
}

.reset-btn-center {
  background: #faad14;
}

.center-btn-icon {
  font-size: 40rpx;
  color: #fff;
}

.center-btn-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
}

/* 公共操作区 */
.action-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
}

.action-title {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
  font-weight: 500;
}

/* 红球按钮 */
.red-ball-btn {
  background: #ff4d4f;
  color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  margin-bottom: 24rpx;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 79, 0.3);
}

/* 彩球按钮区 */
.color-balls {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.color-btn {
  flex: 1;
  min-width: 80rpx;
  padding: 20rpx 10rpx;
  border-radius: 12rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.color-value {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 犯规区 */
.foul-section {
  background: #fff1f0;
  border-radius: 12rpx;
  padding: 24rpx;
}

.foul-title {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
}

.foul-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.foul-btn {
  background: #ff4d4f;
  color: #fff;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  min-width: 80rpx;
  text-align: center;
  font-weight: bold;
  flex: 1;
  max-width: 120rpx;
}
